<Window x:Class="HermesAI.MVVM.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:HermesAI"
        x:Name="RootWindow"
        Title="HermesAI" Height="700" Width="1200"
        Background="#343541" 
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    
  <Border CornerRadius="10" Background="#343541" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/> <RowDefinition Height="*"/>  </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#202123">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="MouseLeftButtonDown">
                        <b:InvokeCommandAction Command="{Binding DragWindowCommand}" 
                                               CommandParameter="{Binding ElementName=RootWindow}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <TextBlock Text="Hermes AI" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="SemiBold" FontSize="13"/>
    
                <Button Content="✕" 
                        HorizontalAlignment="Right" Width="40" Background="Transparent" Foreground="#D1D5DB" BorderThickness="0" FontSize="14" Cursor="Hand"
                        Command="{Binding CloseWindowCommand}" 
                        CommandParameter="{Binding ElementName=RootWindow}"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/> 
                    <ColumnDefinition Width="*"/>   
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Background="#202123">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Margin="10,15,10,10" Padding="10" 
                            Background="Transparent" BorderBrush="#4D4D4F" BorderThickness="1" 
                            Foreground="White" Cursor="Hand" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Margin="0,0,10,0" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Neuer Chat" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel Margin="10,0">
                            <TextBlock Text="Heute" Foreground="#8E8EA0" FontSize="11" Margin="5,0,0,5" FontWeight="SemiBold"/>

                            <ItemsControl ItemsSource="{Binding ChatList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Title}" 
                                                Background="Transparent" 
                                                Foreground="#D1D5DB" 
                                                BorderThickness="0" 
                                                HorizontalContentAlignment="Left" 
                                                Padding="5,8" 
                                                Cursor="Hand"
                                                Command="{Binding DataContext.SelectChatCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="#4D4D4F" BorderThickness="0,1,0,0" Padding="15">
                        <TextBlock Text="⚙ Einstellungen" Foreground="#D1D5DB" Cursor="Hand">
                            <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding OpenSettingsCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </Border>
                </Grid>

                <Grid Grid.Column="1" Background="#343541">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>    
                        <RowDefinition Height="Auto"/> 
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20">
    
                        <ItemsControl ItemsSource="{Binding CurrentChat.Messages}" MaxWidth="800">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
            
                                    <Border x:Name="MessageBorder" 
                                            CornerRadius="8" Padding="15" Margin="0,10,0,10" 
                                            HorizontalAlignment="Left" MaxWidth="650"
                                            Background="Transparent">
                
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    </Grid.ColumnDefinitions>

                                            <Border x:Name="Avatar" Grid.Column="0" Width="30" Height="30" CornerRadius="15" Background="#10A37F" VerticalAlignment="Top" Margin="0,0,15,0">
                                                <TextBlock Text="H" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                            </Border>
                    
                                            <TextBlock Grid.Column="1" Text="{Binding Text}" Foreground="#D1D5DB" TextWrapping="Wrap" LineHeight="22" VerticalAlignment="Center"/>
                                        </Grid>

                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsMyMessage}" Value="True">
                                            <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Right" />
                                            <Setter TargetName="MessageBorder" Property="Background" Value="#444654" />
                                            <Setter TargetName="Avatar" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
            
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
    
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#40414F" CornerRadius="12" Margin="40,0,40,30" MaxWidth="800" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" 
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" Foreground="White" BorderThickness="0" FontSize="15" Padding="10" 
                                     TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="150" VerticalScrollBarVisibility="Auto" CaretBrush="White">
                            </TextBox>

                            <Button Grid.Column="1" 
                                    Command="{Binding SendMessageCommand}"
                                    Background="#10A37F" Foreground="White" BorderThickness="0" Width="35" Height="35"  Margin="5" Cursor="Hand" VerticalAlignment="Bottom">
                                <TextBlock Text="➤" FontSize="16" Margin="2,0,0,0"/>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
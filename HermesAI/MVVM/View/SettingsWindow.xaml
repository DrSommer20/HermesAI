<Window x:Class="HermesAI.MVVM.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HermesAI.MVVM.ViewModel" 
        Title="Einstellungen" Height="250" Width="450"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border CornerRadius="15" Background="#202123" BorderBrush="#4D4D4F" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Google AI Studio API-Key" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Dein API-Key wird verschlüsselt auf diesem PC gespeichert." Foreground="#8E8EA0" FontSize="12" Margin="0,0,0,5"/>
                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#343541" Foreground="White" BorderBrush="#4D4D4F" 
                         Padding="10" FontSize="14" CaretBrush="White"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Abbrechen" Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="Transparent" Foreground="#D1D5DB" BorderThickness="0" Margin="0,0,10,0" Padding="15,5" Cursor="Hand"/>
                <Button Content="Speichern" Command="{Binding SaveAndCloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Background="#10A37F" Foreground="White" BorderThickness="0" Padding="20,8" Cursor="Hand" Width="75">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>